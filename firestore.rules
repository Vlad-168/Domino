rules_version = '2';
// Domino — правила доступа к общему household-документу.
// Пара использует один Firebase-проект и общий код семьи (households/{code}).
// Доступ только аутентифицированным клиентам (анонимная аутентификация),
// что отсекает случайных читателей без токена проекта. Код семьи играет роль
// общего секрета между двумя партнёрами.
service cloud.firestore {
  match /databases/{database}/documents {
    match /households/{code} {
      allow read, write: if request.auth != null;
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
